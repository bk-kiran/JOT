{
  "expo": {
    "name": "JOT",
    "slug": "jot-app",
    "version": "1.0.0",
    "scheme": "jot",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070C14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jot.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "JOT sends reminders for the tasks you capture.",
        "NSCameraUsageDescription": "Used for voice note attachments (coming soon).",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jot.app",
      "adaptiveIcon": {
        "backgroundColor": "#070C14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0DB8F5",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3b854371-1c02-44f1-ac70-1956203fcd39"
      }
    },
    "owner": "bk2005"
  }
}
